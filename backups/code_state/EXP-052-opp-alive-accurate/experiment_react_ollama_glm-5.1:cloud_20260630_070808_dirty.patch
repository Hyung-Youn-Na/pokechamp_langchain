+# ---------------------------------------------------------------------------
+# _opponent_full_team / _opp_alive_count (EXP-052: teampreview merge)
+# ---------------------------------------------------------------------------
+
+
+def _stub_mon(species, fainted=False):
+    """Minimal Pokemon stub — only ``.species`` and ``.fainted`` are read."""
+    return SimpleNamespace(species=species, fainted=fainted)
+
+
+def _battle_with_teams(revealed: dict, preview):
+    """Battle stub exposing the private team attrs the merge helper reads.
+    ``preview`` may be a list in tests — the helper only iterates it (the real
+    attribute is a set, but stubs are unhashable)."""
+    return SimpleNamespace(
+        _opponent_team=revealed,
+        _teampreview_opponent_team=preview,
+    )
+
+
+def test_opp_alive_teampreview_six_revealed_one():
+    """teampreview 6 + revealed 1 (overlapping species) → 6 alive."""
+    revealed = {"gholdengo": _stub_mon("gholdengo")}
+    preview = [
+        _stub_mon(s)
+        for s in [
+            "gholdengo",
+            "roaringmoon",
+            "tinglu",
+            "ogerponwellspring",
+            "ironvaliant",
+            "dragapult",
+        ]
+    ]
+    battle = _battle_with_teams(revealed, preview)
+    assert len(_opponent_full_team(battle)) == 6
+    assert _opp_alive_count(battle) == 6
+    assert _opp_fainted_count(battle) == 0
+
+
+def test_opp_alive_revealed_fainted_merged_with_teampreview():
+    """revealed carries the real faint status; teampreview-only species stay
+    alive. revealed 3 (1 fainted) + preview 6 → 6 species, 1 fainted → 5 alive."""
+    revealed = {
+        "gholdengo": _stub_mon("gholdengo", fainted=False),
+        "dragapult": _stub_mon("dragapult", fainted=True),
+        "tinglu": _stub_mon("tinglu", fainted=False),
+    }
+    preview = [
+        _stub_mon(s)
+        for s in [
+            "gholdengo",
+            "dragapult",
+            "tinglu",
+            "ogerponwellspring",
+            "ironvaliant",
+            "roaringmoon",
+        ]
+    ]
+    battle = _battle_with_teams(revealed, preview)
+    assert _opp_alive_count(battle) == 5
+    assert _opp_fainted_count(battle) == 1
+
+
+def test_opp_alive_empty_preview_falls_back_to_revealed():
+    """Before teampreview lands, the merge degrades to revealed-only (current
+    behaviour) — graceful, no crash."""
+    revealed = {
+        "gholdengo": _stub_mon("gholdengo", fainted=False),
+        "dragapult": _stub_mon("dragapult", fainted=True),
