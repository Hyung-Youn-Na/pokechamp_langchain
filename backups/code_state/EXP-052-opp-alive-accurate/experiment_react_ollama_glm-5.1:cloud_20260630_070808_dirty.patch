+      status가 갱신되지 않아 항상 ``fainted=False`` 다. revealed 객체만
+      실제 status(FNT)를 받는다.
+    - 따라서 species 기준으로 병합하되 **revealed를 우선**(상태 신뢰)하고,
+      teampreview에만 있는 species는 alive(아직 field에 안 나옴)로 둔다.
+    """
+    revealed = getattr(battle, "_opponent_team", None) or {}
+    preview = getattr(battle, "_teampreview_opponent_team", None) or set()
+    by_species: Dict[str, Any] = {}
+    for mon in revealed.values():
+        by_species[to_species_key(str(mon.species))] = mon
+    for mon in preview:
+        k = to_species_key(str(mon.species))
+        if k not in by_species:
+            by_species[k] = mon
+    return list(by_species.values())
+
+
+def _opp_alive_count(battle: Any) -> int:
+    """opponent 팀 중 생존(fainted 아닌) 수 — teampreview 풀 팀 기준 (EXP-052)."""
+    return sum(1 for m in _opponent_full_team(battle) if not m.fainted)
+
+
+def _opp_fainted_count(battle: Any) -> int:
+    """opponent 팀 중 기절(fainted) 수 — teampreview 풀 팀 기준 (EXP-052)."""
