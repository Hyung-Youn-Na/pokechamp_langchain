+# ---------------------------------------------------------------------------
+# Dynamic move resolution helper (EXP-035, 안 B)
+# ---------------------------------------------------------------------------
+
+
+def _apply_dynamic_resolution(move, user, target, ctx):
+    """Return a *copy* of ``move`` with its dynamic type/base_power resolved.
+
+    The LocalSim damage path (``calculate_remaining_hp`` → ``modify_damage``)
+    reads ``move.type`` / ``move.base_power`` as-is and never calls the
+    dynamic resolvers, so a move like Ogerpon-Wellspring's Ivy Cudgel is
+    simulated with its static type (Grass) instead of the real one (Water) —
+    producing spurious "100% HP lost" results (EXP-034 battle-731).
+
+    This mirrors exactly what ``get_move_details`` already shows the LLM, so
+    ``calculate_damage`` / ``simulate_turn`` / ``analyze_matchup`` now agree
+    with it instead of contradicting it. The original (possibly cached) Move
+    object is never mutated — a shallow copy is overridden.
+
+    Fail-safe: returns the original ``move`` unchanged on any error.
+    """
+    if user is None:
+        return move
+    try:
+        resolved = copy.copy(move)
+    except Exception:
+        return move
+
+    # Dynamic type (e.g. Ivy Cudgel → Water for Ogerpon-Wellspring)
+    try:
+        dyn_type = resolve_dynamic_type(
+            move.id,
+            weather=ctx.weather,
+            user=user,
+            tera_type=getattr(user, "_terastallized_type", None),
+            user_species=user.species,
+        )
+        if dyn_type:
+            resolved.type = PokemonType[str(dyn_type).upper()]
+    except Exception:
+        pass
+
+    # Dynamic power (e.g. Acrobatics, Facade, Knock Off, Weather Ball)
+    try:
+        dyn_power = resolve_dynamic_power(
+            move.id,
+            weather=ctx.weather,
+            user=user,
+            target=target,
+            user_item=user.item if user.item else None,
+            user_status=user.status if user.status else None,
+        )
+        if dyn_power is not None:
+            resolved.base_power = dyn_power
+    except Exception:
+        pass
+
+    return resolved
+
+
