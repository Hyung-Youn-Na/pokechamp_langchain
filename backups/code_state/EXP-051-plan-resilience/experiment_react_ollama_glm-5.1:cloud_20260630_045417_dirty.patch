@@ -312,6 +321,45 @@ def plan_is_stale(memory: BattleMemory, current_turn: int, max_age: int = 5) ->
     return (current_turn - memory.plan_turn) > max_age
 
 
+def detect_plan_disruption(
+    memory: BattleMemory, battle: Any
+) -> "tuple[bool, Optional[str]]":
+    """Detect whether ``my_plan`` was disrupted this turn (EXP-051).
+
+    A change in the own active species since last turn (own KO or forced
+    switch) flags the long-term plan as invalidated so the agent is nudged
+    to re-assess its win path — instead of leaning on a plan built around a
+    mon that is now gone.
+
+    Updates the snapshot (``last_my_active_species``) to the current species
+    on every call, establishing the baseline for the next turn's comparison.
+    First-turn calls (empty snapshot) never flag a disruption.
+
+    Returns ``(disrupted, reason)``: ``reason`` is a human-readable nudge
+    when disrupted, else ``None``.
+    """
+    mon = getattr(battle, "active_pokemon", None)
+    if mon is None:
+        return False, None
+
+    curr = to_species_key(getattr(mon, "species", "") or "")
+    if not curr:
+        return False, None
+
+    prev = memory.last_my_active_species
+    disrupted = bool(prev) and curr != prev
+    reason: Optional[str] = None
+    if disrupted:
+        reason = (
+            f"your {prev} was removed (KO/forced switch) — reassess "
+            f"whether your win path still holds"
+        )
+
+    # Snapshot the current active so the next call compares against it.
+    memory.last_my_active_species = curr
+    return disrupted, reason
+
+
